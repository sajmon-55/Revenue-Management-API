### Zmienne globalne (Zmień port jeśli masz inny)
@host = http://localhost:5168
@token = {{login.response.body.$}} 

### 1. LOGOWANIE (Pobieranie tokena)
# @name login
POST {{host}}/api/Auth/sign-in
Content-Type: application/json

{
  "login": "admin",
  "password": "Password123@"
}

